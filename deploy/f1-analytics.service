[Unit]
Description=F1 Analytics Dashboard
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/f1-analytics
ExecStart=/opt/f1-analytics/venv/bin/gunicorn app:server -b 127.0.0.1:8003 -w 2 --threads 4 --worker-class gthread --timeout 180 --graceful-timeout 30 --max-requests 200 --max-requests-jitter 25
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
